# =============================================
# CONFIGURAÇÕES DO SISTEMA DE TICKETS
# Copie este arquivo para .env e preencha
# =============================================

# Ambiente (production em produção, development local)
NODE_ENV=production

# Porta do servidor (apenas para rodar localmente)
PORT=3000

# Segredo da sessão (use uma string longa e aleatória — mínimo 32 caracteres)
SESSION_SECRET=gere-uma-string-aleatoria-longa-aqui

# Chave de criptografia dos dados no banco (NUNCA mude após ter dados gravados)
# Se não definida, usa SESSION_SECRET como fallback
ENCRYPTION_SECRET=gere-outra-string-aleatoria-longa-aqui

# =============================================
# SUPABASE
# =============================================
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# =============================================
# DISCORD OAUTH2
# Crie em: https://discord.com/developers/applications
# Redirect URI deve ser: https://SEU_DOMINIO.vercel.app/auth/discord/callback
# =============================================
DISCORD_CLIENT_ID=seu_client_id_aqui
DISCORD_CLIENT_SECRET=seu_client_secret_aqui
DISCORD_REDIRECT_URI=https://SEU_DOMINIO.vercel.app/auth/discord/callback

# =============================================
# DISCORD BOT TOKEN
# Token do bot para buscar/gerenciar cargos dos membros
# O bot precisa estar no servidor com permissão "Manage Roles" e "Server Members Intent"
# =============================================
DISCORD_BOT_TOKEN=seu_bot_token_aqui

# =============================================
# ADMIN
# ID do Discord do administrador (seu ID numérico)
# =============================================
ADMIN_DISCORD_ID=seu_discord_id_aqui
